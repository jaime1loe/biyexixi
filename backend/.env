# FastAPI 应用配置
APP_NAME=基于大模型智能体的高校知识库在线答疑系统
APP_VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=qa_system
DB_USER=root
DB_PASSWORD=12345678

# 使用SQLite数据库（如果MySQL不可用）
# 取消下面注释以使用SQLite
# USE_SQLITE=True

# JWT 配置
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB

# 向量数据库配置
VECTOR_DB_PATH=./data/vector_db

# AI 模型配置
LLM_MODEL=chatglm3-6b
LLM_BASE_URL=http://localhost:8001
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
